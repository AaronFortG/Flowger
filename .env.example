# Environment configuration for Flowger
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./flowger.db

# ── Exports ──────────────────────────────────────────────────────────────────
EXPORTS_DIR=./exports

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Banking provider ─────────────────────────────────────────────────────────
# Use "stub" for local development (no credentials required).
# Use "enable_banking" to connect to a real bank via Enable Banking API.
PROVIDER=stub

# ── Enable Banking (only required when PROVIDER=enable_banking) ──────────────
ENABLE_BANKING_BASE_URL=https://api.enablebanking.com
ENABLE_BANKING_API_KEY=your-api-key-here
